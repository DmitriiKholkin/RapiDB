    "configuration": {
      "title": "RapiDB",
      "properties": {
        "rapidb.connections": {
          "type": "array",
          "default": [],
          "description": "List of saved database connections",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique connection identifier (auto-generated)"
              },
              "name": {
                "type": "string",
                "description": "Display name shown in the explorer tree"
              },
              "type": {
                "type": "string",
                "enum": [
                  "mysql",
                  "pg",
                  "sqlite",
                  "mssql",
                  "oracle",
                  "mongodb",
                  "redis",
                  "elasticsearch",
                  "dynamodb"
                ],
                "description": "Database engine type"
              },
              "host": {
                "type": "string",
                "description": "Hostname or IP address"
              },
              "port": {
                "type": "number",
                "description": "TCP port (defaults: pg=5432, mysql=3306, mssql=1433, oracle=1521)"
              },
              "database": {
                "type": "string",
                "description": "Database name. For Oracle used as service name when oracleSettings.serviceName is not set."
              },
              "username": {
                "type": "string",
                "description": "Login username"
              },
              "password": {
                "type": "string",
                "description": "Login password for the database connection."
              },
              "filePath": {
                "type": "string",
                "description": "SQLite only: absolute path to the .db file"
              },
              "ssl": {
                "type": "boolean",
                "default": false,
                "description": "Enable SSL/TLS encryption. Not applicable to SQLite."
              },
              "rejectUnauthorized": {
                "type": "boolean",
                "default": true,
                "description": "When ssl is true: reject self-signed or untrusted certificates. Set to false to allow self-signed certs."
              },
              "folder": {
                "type": "string",
                "description": "Optional folder name for grouping connections in the explorer tree"
              },
              "readOnly": {
                "type": "boolean",
                "default": false,
                "description": "Open the connection in read-only mode. Query execution is limited to read operations and table edits are blocked."
              },
              "serviceName": {
                "type": "string",
                "description": "Oracle service name (e.g. XEPDB1). Preferred over SID. If omitted, the database field is used."
              },
              "connectionUri": {
                "type": "string",
                "description": "Connection URI for MongoDB or other URI-based drivers."
              },
              "endpoint": {
                "type": "string",
                "description": "Custom service endpoint for Elasticsearch or DynamoDB."
              },
              "apiKey": {
                "type": "string",
                "description": "Elasticsearch API key used instead of basic auth."
              },
              "cloudId": {
                "type": "string",
                "description": "Elastic Cloud deployment identifier."
              },
              "awsRegion": {
                "type": "string",
                "description": "AWS region for DynamoDB connections."
              },
              "awsAccessKeyId": {
                "type": "string",
                "description": "AWS access key ID for DynamoDB."
              },
              "awsSecretAccessKey": {
                "type": "string",
                "description": "AWS secret access key for DynamoDB."
              },
              "awsSessionToken": {
                "type": "string",
                "description": "Optional AWS session token for temporary credentials."
              },
              "awsProfile": {
                "type": "string",
                "description": "Shared AWS profile name to use for DynamoDB credentials."
              }
            }
          },
          "scope": "application"
        },
        "rapidb.queryRowLimit": {
          "type": "number",
          "default": 10000,
          "minimum": 100,
          "maximum": 100000,
          "description": "Maximum number of rows returned by a query in the SQL editor. If the result exceeds this limit, rows are trimmed and a warning is shown. Range: 100–100 000. Set to 100000 to effectively disable the limit.",
          "scope": "application"
        },
        "rapidb.connectionTimeoutSeconds": {
          "type": "number",
          "default": 15,
          "minimum": 1,
          "maximum": 3600,
          "description": "Timeout in seconds for establishing a database connection. Applies to all drivers.",
          "scope": "application"
        },
        "rapidb.dbOperationTimeoutSeconds": {
          "type": "number",
          "default": 180,
          "minimum": 1,
          "maximum": 3600,
          "description": "Timeout in seconds for database operations, including SQL editor queries, table/view reads, metadata, DDL, and routine loading. Applies to all drivers.",
          "scope": "application"
        },
        "rapidb.queryHistoryLimit": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "maximum": 10000,
          "description": "Maximum number of queries stored in history (shared across all connections). Must be between 1 and 10000. If you lower this value, excess entries are trimmed immediately.",
          "scope": "application"
        },
        "rapidb.defaultPageSize": {
          "type": "number",
          "default": 25,
          "enum": [
            25,
            100,
            500,
            1000
          ],
          "description": "Default number of rows per page in the Table Data Viewer. Allowed values: 25, 100, 500, 1000. Any other value will be ignored and 25 will be used.",
          "scope": "application"
        },
        "rapidb.skipTableMutationPreview": {
          "type": "boolean",
          "default": false,
          "description": "Apply insert, edit, and delete actions in the Table Data Viewer without opening the mutation preview dialog.",
          "scope": "application"
        }
      }
    },
    "viewsWelcome": [
      {
        "view": "rapidb-explorer",
        "contents": "No database connections yet.\n[Add Connection](command:rapidb.addConnection)\n\nLearn how to use [RapiDB](https://github.com/rapidb/rapidb)."
      },
      {
        "view": "rapidb-history",
        "contents": "No query history yet.\nExecute a query in the SQL editor to see it here."
      },
      {
        "view": "rapidb-bookmarks",
        "contents": "No bookmarks yet.\nClick the bookmark button in the SQL editor to save a query here."
      }
    ]
  },
  "scripts": {
    "package:prepare": "node ./scripts/prepare-vscode-package.mjs",
    "vscode:prepublish": "npm run package:prepare && node esbuild.config.mjs --production",
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "compile": "npm run build",
    "check": "npm run typecheck && npm run lint",
    "lint": "biome check . --max-diagnostics=none",
    "lint:fix": "biome check . --write --unsafe --max-diagnostics=none",
    "typecheck": "npm run typecheck:extension && npm run typecheck:webview && npm run typecheck:tests",
    "typecheck:extension": "tsc -p tsconfig.extension.json --noEmit",
    "typecheck:webview": "tsc -p tsconfig.webview.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.tests.json --noEmit",
    "test": "npm run test:all",
    "test:all": "node ./tests/scripts/run-npm-scripts.mjs compile typecheck test:unit test:webview test:db test:extension",
    "test:unit": "vitest run --project unit-node",
    "test:webview": "vitest run --project webview-jsdom",
    "test:db": "node ./tests/scripts/run-npm-scripts.mjs db:up db:prepare test:db:sqlite test:db:postgres test:db:mysql test:db:mssql test:db:oracle test:db:nosql db:down --finally-if-env-not RAPIDB_KEEP_TEST_SERVICES",
    "test:db:sqlite": "vitest run --project db-sqlite",
    "test:db:postgres": "vitest run --project db-postgres",
    "test:db:mysql": "vitest run --project db-mysql",
    "test:db:mssql": "vitest run --project db-mssql",
    "test:db:oracle": "vitest run --project db-oracle",
    "test:db:nosql": "node ./tests/scripts/run-nosql-vitest.mjs",
    "test:extension": "vitest run --project extension-host",
    "db:check": "node ./tests/scripts/db-check.mjs",
    "db:up": "npm run db:check && docker compose -f ./compose.yaml up -d --build ssh-bastion postgres mysql mssql oracle redis mongo elasticsearch dynamodb",
    "db:wait": "tsx ./tests/scripts/db-wait.ts",
    "db:reset": "tsx ./tests/scripts/db-reset.ts",
    "db:seed": "tsx ./tests/scripts/db-seed.ts",
    "db:prepare": "node ./tests/scripts/run-npm-scripts.mjs db:wait db:reset db:seed",
    "db:down": "docker compose -f ./compose.yaml down --remove-orphans",
    "package": "vsce package"
  },
