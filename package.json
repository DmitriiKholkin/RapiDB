  "publisher": "DmitriiKholkin",
  "repository": {
    "type": "git",
    "url": "https://github.com/DmitriiKholkin/RapiDB"
  },
  "icon": "./media/icon-market.png",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Data Science",
    "Other"
  ],
  "keywords": [
    "sql",
    "database",
    "db",
    "postgresql",
    "postgres",
    "mysql",
    "sqlite",
    "mssql",
    "sql server",
    "mariadb",
